# Example environment configuration (do not put secrets into git)

# LLM provider configuration (examples)
# OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional: local paths
# AI_IDE_APPDATA_DIR=AppData

# Webapp persistence
# ALDE_WEB_DATABASE_URL=postgresql+psycopg://alde:alde@localhost:5432/alde_web

# Webapp OIDC / SSO
# ALDE_WEB_OIDC_ISSUER=https://keycloak.example/realms/alde
# ALDE_WEB_OIDC_CLIENT_ID=alde-web
# ALDE_WEB_OIDC_CLIENT_SECRET=change-me
# ALDE_WEB_OIDC_REDIRECT_URI=http://localhost:8080/api/v1/auth/oidc/callback
# ALDE_WEB_OIDC_SCOPE=openid profile email
# ALDE_WEB_OIDC_AUDIENCE=alde-web
# ALDE_WEB_OIDC_JWKS_URL=https://keycloak.example/realms/alde/protocol/openid-connect/certs
# ALDE_WEB_OIDC_VERIFY_EXP=1
# ALDE_WEB_OIDC_ADMIN_GROUPS=alde-admin,tenant-admin
# ALDE_WEB_OIDC_ADMIN_EMAIL_DOMAINS=example.com
# ALDE_WEB_REFRESH_TTL_DAYS=14
# ALDE_WEB_RBAC_MEMBER_AGENTS=_primary_assistant,_data_dispatcher
# ALDE_WEB_RBAC_MEMBER_TOOLS=

# Queue backend
# ALDE_WEB_QUEUE_BACKEND=inmemory
# ALDE_WEB_REDIS_URL=redis://localhost:6379/0
# ALDE_WEB_RQ_QUEUE=alde-agent-runs
# ALDE_WEB_RQ_JOB_TIMEOUT_SECONDS=120
# ALDE_WEB_RQ_RESULT_TTL_SECONDS=600
# ALDE_WEB_RQ_FAILURE_TTL_SECONDS=86400
# ALDE_WEB_RQ_RETRY_MAX=2
# ALDE_WEB_RQ_RETRY_INTERVALS=2,5

# Optional AgentsDB knowledge backend (preferred)
# AI_IDE_KNOWLEDGE_AGENTS_DB_URI=agentsdb://localhost:2331
# AI_IDE_KNOWLEDGE_AGENTS_DB_BACKEND_URI=agentsmem://local
# AI_IDE_KNOWLEDGE_AGENTS_DB_CONFIG_PATH=AppData/agentsdb_connection.json
# AI_IDE_KNOWLEDGE_AGENTS_DB_NAME=alde_knowledge
# AI_IDE_KNOWLEDGE_AGENTS_DB_TENANT_ID=tenant_default
# AI_IDE_KNOWLEDGE_AGENTS_DB_NAMESPACE_ID=ns_alde_default
# AI_IDE_KNOWLEDGE_AGENTS_DB_NAMESPACE_SLUG=alde-default
# AI_IDE_KNOWLEDGE_AGENTS_DB_NAMESPACE_NAME=ALDE Default Knowledge
# AI_IDE_KNOWLEDGE_AGENTS_DB_EMBEDDING_MODEL=text-embedding-3-large
# AI_IDE_KNOWLEDGE_AGENTS_DB_EMBEDDING_DIMENSION=3072

# Optional MongoDB knowledge mirror for document, dispatcher, and retrieval runtime data (legacy)
# AI_IDE_KNOWLEDGE_MONGO_URI=mongodb://localhost:27017
# AI_IDE_KNOWLEDGE_MONGO_DB=alde_knowledge
# AI_IDE_KNOWLEDGE_MONGO_TENANT_ID=tenant_default
# AI_IDE_KNOWLEDGE_MONGO_NAMESPACE_ID=ns_alde_default
# AI_IDE_KNOWLEDGE_MONGO_NAMESPACE_SLUG=alde-default
# AI_IDE_KNOWLEDGE_MONGO_NAMESPACE_NAME=ALDE Default Knowledge
# AI_IDE_KNOWLEDGE_MONGO_EMBEDDING_MODEL=text-embedding-3-large
# AI_IDE_KNOWLEDGE_MONGO_EMBEDDING_DIMENSION=3072
# AI_IDE_KNOWLEDGE_MONGO_INDEX_BACKEND=faiss

# Optional local OIDC callback mocking for development
# ALDE_WEB_OIDC_DEV_MOCK=1
