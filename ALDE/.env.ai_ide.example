# AI IDE startup configuration template
# Copy this file to .env and fill in real secrets locally.

# Socket endpoint used by ALDE clients
AI_IDE_KNOWLEDGE_AGENTS_DB_URI=agentsdb://localhost:2331

# Backend used by the local agentsdb socket server
AI_IDE_KNOWLEDGE_AGENTS_DB_BACKEND_URI=agentsmem://local
AI_IDE_KNOWLEDGE_AGENTS_DB_NAME=alde_knowledge
AI_IDE_KNOWLEDGE_AGENTS_DB_MEMORY_IMAGE_PATH=AppData/agentsdb_memory_image.json
AI_IDE_AGENTS_DB_PIPELINE_STRICT=1

# Optional namespace defaults
AI_IDE_KNOWLEDGE_AGENTS_DB_TENANT_ID=tenant_default
AI_IDE_KNOWLEDGE_AGENTS_DB_NAMESPACE_ID=ns_alde_default
AI_IDE_KNOWLEDGE_AGENTS_DB_NAMESPACE_SLUG=alde-default
AI_IDE_KNOWLEDGE_AGENTS_DB_NAMESPACE_NAME=ALDE Default Knowledge
AI_IDE_KNOWLEDGE_AGENTS_DB_EMBEDDING_MODEL=text-embedding-3-large
AI_IDE_KNOWLEDGE_AGENTS_DB_EMBEDDING_DIMENSION=3072
AI_IDE_KNOWLEDGE_AGENTS_DB_INDEX_BACKEND=faiss
AI_IDE_AGENTS_DB_TREE_STRICT=1
AI_IDE_TREE_AGENTS_DB_OBJECT_ID=tree_widget:tree_data

# Startup helper paths
AI_IDE_STARTUP_ENV_FILE_PATH=ALDE/.env
AI_IDE_AGENTSDB_SERVER_SCRIPT_PATH=scripts/start_agentsdb_socket_server.py

# API keys (set your real values only in .env, never in git)
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
